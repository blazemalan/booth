#!/bin/bash
# booth — voice on-ramp + off-ramp for an MCP-bridged Telegram channel.
#
# Booth doesn't bridge Telegram itself — that's the MCP plugin's job (Anthropic's
# Telegram channel, OpenClaw's Telegram skill, etc.). Booth is the voice layer
# that drops in alongside whichever bridge you already run.
#
# Usage:
#   booth say "Hello, Blaze."          # synth + sendVoice via Telegram Bot API
#   booth say --voice af_bella "..."   # custom voice
#   booth transcribe path/audio.oga    # whisper.cpp → text on stdout
#   booth inject "/compact"            # AppleScript-type into front Terminal
#   booth daemon                       # foreground voice daemon (debug only)
#   booth status                       # daemon health

set -e

BOOTH_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )/.." && pwd )"
SRC_DIR="$BOOTH_DIR/src"
# Prefer the runtime venv that install.sh creates (kokoro_onnx + onnxruntime
# + numpy live there). Fall back to system python3 if the venv isn't set up
# yet — say/transcribe will still work for daemon-already-running cases.
RUNTIME_PY="${HOME}/.local/share/booth/.venv/bin/python"
if [ -n "${BOOTH_PY:-}" ]; then
  PY="$BOOTH_PY"
elif [ -x "$RUNTIME_PY" ]; then
  PY="$RUNTIME_PY"
else
  PY="python3"
fi

cmd="${1:-help}"
shift || true

case "$cmd" in
  say)
    exec "$PY" "$SRC_DIR/say.py" "$@"
    ;;
  transcribe|stt)
    exec "$PY" "$SRC_DIR/stt.py" "$@"
    ;;
  inject)
    exec "$PY" "$SRC_DIR/injector.py" "$@"
    ;;
  daemon)
    exec "$PY" "$SRC_DIR/voice_daemon.py" "$@"
    ;;
  status)
    if [ -S /tmp/booth_voice.sock ]; then
      echo "voice daemon: running (socket present)"
    else
      echo "voice daemon: not running (will auto-spawn on first 'booth say')"
    fi
    ;;
  help|--help|-h|"")
    echo "Booth — voice layer for your MCP-bridged Telegram channel."
    echo
    echo "Commands:"
    echo "  booth say TEXT             send a Telegram voice bubble"
    echo "  booth transcribe FILE      whisper transcript of an audio file"
    echo "  booth inject TEXT          type into front Terminal session (Claude Code)"
    echo "  booth daemon               run the TTS daemon manually"
    echo "  booth status               check daemon health"
    ;;
  *)
    echo "Unknown command: $cmd" >&2
    echo "Try: booth help" >&2
    exit 1
    ;;
esac
