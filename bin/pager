#!/bin/bash
# pager — convenience CLI wrapping src/say.py, src/listen.py, src/stt.py.
#
# Usage:
#   pager say "Hello, Blaze."
#   pager say --voice af_bella "Custom voice."
#   pager listen                          # start the inbound listener (foreground)
#   pager stt path/to/audio.oga           # transcribe a file
#   pager inject "/compact"               # type into front Terminal session
#   pager status                          # daemon + listener health

set -e

PAGER_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )/.." && pwd )"
SRC_DIR="$PAGER_DIR/src"
PY="${PAGER_PY:-python3}"

cmd="${1:-help}"
shift || true

case "$cmd" in
  say)
    exec "$PY" "$SRC_DIR/say.py" "$@"
    ;;
  listen)
    exec "$PY" "$SRC_DIR/listen.py" "$@"
    ;;
  stt)
    exec "$PY" "$SRC_DIR/stt.py" "$@"
    ;;
  inject)
    exec "$PY" "$SRC_DIR/injector.py" "$@"
    ;;
  daemon)
    exec "$PY" "$SRC_DIR/voice_daemon.py" "$@"
    ;;
  status)
    if [ -S /tmp/pager_voice.sock ]; then
      echo "voice daemon: running (socket present)"
    else
      echo "voice daemon: not running"
    fi
    if pgrep -f "src/listen.py" >/dev/null; then
      echo "listener:     running"
    else
      echo "listener:     not running"
    fi
    ;;
  help|--help|-h|"")
    echo "Pager — voice notes from your AI agent, over Telegram."
    echo
    echo "Commands:"
    echo "  pager say TEXT          send a Telegram voice bubble"
    echo "  pager listen            start the inbound voice listener"
    echo "  pager stt FILE          transcribe an audio file"
    echo "  pager inject TEXT       type into front Terminal session (Claude Code)"
    echo "  pager daemon            run the TTS daemon manually"
    echo "  pager status            check daemon + listener state"
    ;;
  *)
    echo "Unknown command: $cmd" >&2
    echo "Try: pager help" >&2
    exit 1
    ;;
esac
